{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/run-mfe-commands.js dev",
    "dev:host": "vite --config apps/host/vite.config.js",
    "dev:auth": "vite --config apps/auth/vite.config.js",
    "dev:progress": "vite --config apps/progress/vite.config.js",
    "build": "node scripts/run-mfe-commands.js build",
    "build:host": "vite build --config apps/host/vite.config.js",
    "build:auth": "vite build --config apps/auth/vite.config.js",
    "build:progress": "vite build --config apps/progress/vite.config.js",
    "lint": "eslint \"apps/**/*.{js,jsx}\" \"scripts/**/*.js\"",
    "preview": "vite preview --config apps/host/vite.config.js"
  },
  "dependencies": {
    "@apollo/client": "^4.1.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "axios": "^1.13.6",
    "graphql": "^16.13.0",
    "maath": "^0.10.8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.13.1",
    "rxjs": "^7.8.2",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@originjs/vite-plugin-federation": "^1.4.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^7.3.1"
  }
}
